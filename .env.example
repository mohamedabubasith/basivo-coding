# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
# Comma-separated list of allowed CORS origins (no trailing slash)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/basivo

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_me_with_64_hex_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# ── Encryption (API keys at rest) ─────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_me_with_fernet_generated_key

# ── Password reset ────────────────────────────────────────────────────────────
RESET_TOKEN_EXPIRE_MINUTES=30

# ── OpenCode CLI ──────────────────────────────────────────────────────────────
# Path to the opencode binary, or just "opencode" if it's on PATH
OPENCODE_BINARY=opencode
# Root directory for per-project workspace folders.
# DOCKER: bind-mount this path into the OpenCode container.
PROJECTS_ROOT=/app/projects
# Maximum runtime for a single OpenCode invocation (seconds)
OPENCODE_TIMEOUT_SECONDS=300

# ── Dev helpers ───────────────────────────────────────────────────────────────
# Set to true to auto-create DB tables on startup (dev only — use alembic in prod)
CREATE_TABLES=false
